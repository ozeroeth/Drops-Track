# Required secrets for the check-deadlines and send-test-notification functions.
# Set these with the Supabase CLI before deploying:
#   supabase secrets set TELEGRAM_BOT_TOKEN=xxx SUPABASE_SERVICE_ROLE_KEY=xxx
TELEGRAM_BOT_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_URL and SUPABASE_ANON_KEY are injected automatically by the platform
# at runtime. You do not need to set them here.
